{
  "expo": {
    "name": "ROAR",
    "slug": "roar",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "roar",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.roar.app"
    },
    "android": {
      "package": "com.roar.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06060f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E8002D",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O ROAR precisa da câmera para gravar sua reação.",
          "microphonePermission": "O ROAR precisa do microfone para capturar o áudio da sua reação.",
          "recordAudioAndroid": true
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
